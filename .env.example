# Configure these before the first preview or production deployment
# where Phase 7 sharing/persistence must work end to end:
# - POST /api/match persists result tokens
# - GET /api/results/[token] looks up persisted results
# - /r/[token] renders shared results
#
# Local development can omit them if you are only working on quiz/results UI.

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
