#!/bin/sh
# Pre-commit hook — runs on every commit.
# Installed via: npm run prepare
# To bypass in an emergency: git commit --no-verify (requires explicit decision)

echo "pre-commit: checking staged changes..."

# Whitespace — catches trailing spaces, mixed indentation
git diff --cached --check

echo "pre-commit: running npm test..."
npm test

echo "pre-commit: running npm run lint..."
npm run lint
